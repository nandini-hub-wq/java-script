<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>JavaScript Console Demo</title>
<style>
  body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: linear-gradient(to right, #a8edea, #fed6e3);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100vh;
  }
  h1 {
    color: purple;
    font-size: 2em;
    margin-bottom: 10px;
  }
  p {
    color: #fff;
    margin-bottom: 20px;
  }
  .buttons {
    display: flex;
    gap: 15px;
  }
  button {
    padding: 12px 24px;
    border: none;
    border-radius: 8px;
    color: #fff;
    font-weight: bold;
    cursor: pointer;
    font-size: 1em;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    transition: background 0.3s;
  }
  .inline {
    background-color: #ff7f50;
  }
  .inline:hover {
    background-color: #ff6333;
  }
  .internal {
    background-color: #28a745;
  }
  .internal:hover {
    background-color: #218838;
  }
  .external {
    background-color: #007bff;
  }
  .external:hover {
    background-color: #0069d9;
  }
  footer {
    margin-top: 30px;
    font-size: 0.9em;
    color: #fff;
  }
</style>
</head>
<body>

<h1>Welcome to the JavaScript Console Demo</h1>
<p>Click the buttons below to see different JavaScript console methods in action!</p>
<div class="buttons">
  <button class="inline" onclick="consoleInline()">Inline JS Demo</button>
  <button class="internal" onclick="consoleInternal()">Internal JS Demo</button>
  <button class="external" onclick="consoleExternal()">External JS Demo</button>
</div>
<footer>© 2024 Your Name. All rights reserved.</footer>

<script>
  function consoleInline() {
    console.log("This is an inline JS console log!");
  }

  function consoleInternal() {
    // You can add more internal demonstration functions here
    console.info("This is an internal JS console info!");
  }

  function consoleExternal() {
    // You can simulate external script call
    console.warn("This is an external JS console warning!");
  }
</script>

</body>
</html>
