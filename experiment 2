<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title>Billing Calculator</title>
    <!-- Google Fonts for elegant font style -->
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 40px;
            background-color: #fff8e1; /* Bright warm background */
        }
        /* Company Name Style */
        .company-name {
            text-align: center;
            font-family: 'Pacifico', cursive; /* Elegant font */
            font-size: 48px;
            font-weight: bold;
            color: #ff5722; /* Bright orange color */
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            margin-bottom: 10px;
        }
        /* Heading Style */
        h2 {
            text-align: center;
            color: #d84315;
            margin-bottom: 20px;
        }
        /* Button Style */
        #generateBtn {
            display: block;
            margin: 20px auto;
            padding: 12px 25px;
            font-size: 18px;
            background-color: #f57c00;
            color: white;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            transition: background-color 0.3s, transform 0.2s;
        }
        #generateBtn:hover {
            background-color: #ef6c00;
            transform: scale(1.05);
        }
        /* Output container */
        #output {
            margin-top: 30px;
            display: flex;
            justify-content: center;
        }
        /* Bill styling */
        .bill {
            background: linear-gradient(135deg, #ffe0b2, #ffe57f);
            padding: 25px;
            border-radius: 15px;
            width: 90%;
            max-width: 750px;
            box-shadow: 0 6px 20px rgba(0,0,0,0.3);
            font-family: 'Courier New', Courier, monospace;
            color: #333;
            white-space: pre-wrap;
            font-size: 16px;
            line-height: 1.6;
        }
        /* Footer style */
        .footer {
            text-align: center;
            margin-top: 20px;
            font-style: italic;
            color: #555;
        }
        /* Emphasized total */
        .total {
            color: #d32f2f;
            font-weight: bold;
        }
    </style>
</head>
<body>

<!-- Company Name -->
<div class="company-name">Uttar Disha</div>

<h2>Billing Calculator</h2>

<button id="generateBtn">Generate Bill</button>

<div id="output"></div>

<script>
    // Constant for GST
    const GST = 0.18;

    document.getElementById('generateBtn').addEventListener('click', function() {
        // Fixed your name and PRN
        const customerName = "Nandini Daharwal";
        const prn = "24070521152";

        // Prompt for product details
        const productName = prompt("Enter the product name:");
        const quantity = parseInt(prompt("Enter the quantity:"), 10);
        const pricePerUnit = parseFloat(prompt("Enter the price per product:"));

        // Calculate totals
        const totalPrice = quantity * pricePerUnit;
        const gstAmount = totalPrice * GST;
        const totalPayable = totalPrice + gstAmount;

        // Build the bill with styling
        const bill = `
        =================== Billing Receipt ===================

        Name            : ${customerName}
        PRN             : ${prn}
        Product Name    : ${productName}
        Quantity        : ${quantity}
        Price per Unit  : $${pricePerUnit.toFixed(2)}
        -----------------------------------------------------
        Total Price     : $${totalPrice.toFixed(2)}
        GST (${(GST*100).toFixed(0)}%)  : $${gstAmount.toFixed(2)}
        -----------------------------------------------------
        <span class="total">Total Payable : $${totalPayable.toFixed(2)}</span>

        =========================================================
        <div class="footer">Thank you for shopping with us!</div>
        `;

        // Display the bill
        document.getElementById('output').innerHTML = `<div class="bill">${bill}</div>`;
    });
</script>

</body>
</html>
