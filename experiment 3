<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<title>Marks Grading System</title>
<!-- Google Font for elegant style -->
<link href="https://fonts.googleapis.com/css2?family=Pacifico&display=swap" rel="stylesheet" />
<style>
  body {
    font-family: Arial, sans-serif;
    margin: 40px;
    background-color: #fff8e1;
  }
  /* College Name Style */
  .college-name {
    text-align: center;
    font-family: 'Pacifico', cursive;
    font-size: 48px;
    font-weight: bold;
    color: #3f51b5; /* Bright blue color for college */
    text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    margin-bottom: 5px;
  }
  /* Student Info Style */
  .student-info {
    text-align: center;
    font-family: 'Arial', sans-serif;
    font-size: 18px;
    margin-bottom: 20px;
    color: #333;
  }
  h2 {
    text-align: center;
    color: #d84315;
    margin-bottom: 20px;
  }
  form {
    max-width: 500px;
    margin: 0 auto 30px auto;
    padding: 20px;
    background-color: #ffe0b2;
    border-radius: 10px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
  }
  label {
    display: block;
    margin-bottom: 8px;
    font-weight: bold;
  }
  input[type="number"] {
    width: 100%;
    padding: 8px;
    margin-bottom: 15px;
    border-radius: 5px;
    border: 1px solid #ccc;
  }
  /* Subject input styles */
  .subject-input {
    margin-bottom: 15px;
  }
  button {
    width: 100%;
    padding: 12px;
    font-size: 16px;
    background-color: #f57c00;
    color: white;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: background-color 0.3s, transform 0.2s;
  }
  button:hover {
    background-color: #ef6c00;
    transform: scale(1.05);
  }
  #result {
    max-width: 600px;
    margin: 0 auto;
  }
  .grades-container {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  .grade-box {
    background: linear-gradient(135deg, #ffe0b2, #ffe57f);
    padding: 15px;
    border-radius: 10px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    font-family: 'Courier New', Courier, monospace;
    font-size: 16px;
    text-align: center;
  }
  .error {
    color: red;
    text-align: center;
    margin-bottom: 10px;
  }
</style>
</head>
<body>

<!-- College Name -->
<div class="college-name">Symbiosis Institute Nagpur</div>

<!-- Student Information -->
<div class="student-info">
  <strong>Name:</strong> Nandini Daharwal<br/>
  <strong>PRN:</strong> 24070521152<br/>
  <strong>Section:</strong> C<br/>
  <strong>Year:</strong> 3rd
</div>

<h2>Marks Grading System</h2>

<form id="marksForm">
  <!-- Subject inputs -->
  <div class="subject-input">
    <label for="jsMarks">JavaScript Marks (0-100):</label>
    <input type="number" id="jsMarks" name="jsMarks" min="0" max="100" required />
  </div>
  <div class="subject-input">
    <label for="dcMarks">Data Compression Marks (0-100):</label>
    <input type="number" id="dcMarks" name="dcMarks" min="0" max="100" required />
  </div>
  <div class="subject-input">
    <label for="cnMarks">Computer Network Marks (0-100):</label>
    <input type="number" id="cnMarks" name="cnMarks" min="0" max="100" required />
  </div>
  <div class="error" id="errorMsg"></div>
  <button type="submit">Get Grades</button>
</form>

<div id="result"></div>

<script>
  document.getElementById('marksForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const errorMsg = document.getElementById('errorMsg');
    const resultDiv = document.getElementById('result');

    // Clear previous messages
    errorMsg.textContent = '';
    resultDiv.innerHTML = '';

    // Retrieve input values
    const jsMarks = parseFloat(document.getElementById('jsMarks').value);
    const dcMarks = parseFloat(document.getElementById('dcMarks').value);
    const cnMarks = parseFloat(document.getElementById('cnMarks').value);

    // Validate inputs using control structures
    if (
      isNaN(jsMarks) || isNaN(dcMarks) || isNaN(cnMarks) ||
      jsMarks < 0 || jsMarks > 100 ||
      dcMarks < 0 || dcMarks > 100 ||
      cnMarks < 0 || cnMarks > 100
    ) {
      errorMsg.textContent = 'Please enter valid marks between 0 and 100 for all subjects.';
      return;
    }

    // Function to determine grade based on marks
    function getGrade(marks) {
      if (marks >= 90) {
        return 'A+ (Excellent)';
      } else if (marks >= 80) {
        return 'A (Very Good)';
      } else if (marks >= 70) {
        return 'B+ (Good)';
      } else if (marks >= 60) {
        return 'B (Average)';
      } else if (marks >= 50) {
        return 'C (Pass)';
      } else {
        return 'Fail (Needs Improvement)';
      }
    }

    // Calculate grades
    const gradeJS = getGrade(jsMarks);
    const gradeDC = getGrade(dcMarks);
    const gradeCN = getGrade(cnMarks);

    // Display results
    resultDiv.innerHTML = `
      <div class="grades-container">
        <div class="grade-box">
          <strong>JavaScript</strong><br/>
          Marks: ${jsMarks}<br/>
          Grade: <strong>${gradeJS}</strong>
        </div>
        <div class="grade-box">
          <strong>Data Compression</strong><br/>
          Marks: ${dcMarks}<br/>
          Grade: <strong>${gradeDC}</strong>
        </div>
        <div class="grade-box">
          <strong>Computer Network</strong><br/>
          Marks: ${cnMarks}<br/>
          Grade: <strong>${gradeCN}</strong>
        </div>
      </div>
    `;
  });
</script>

</body>
</html>
